---
import { primaryNavigation, site } from "../data/site";
import BrandMark from "./BrandMark.astro";

type Props = { currentPath: string };
const { currentPath } = Astro.props;

const isCurrent = (href: string) =>
  currentPath === href || currentPath.startsWith(href);
---

<header class="site-header">
  <div class="shell header-inner">
    <a class="brand-link" href="/" aria-label="QuireForge home">
      <BrandMark size={38} />
      <span>
        <strong>{site.name}</strong>
        <small>{site.tagline}</small>
      </span>
    </a>

    <nav class="desktop-nav" aria-label="Primary navigation">
      {
        primaryNavigation.map((item) => (
          <a
            href={item.href}
            aria-current={isCurrent(item.href) ? "page" : undefined}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="header-actions">
      <button
        class="theme-toggle"
        type="button"
        data-theme-toggle
        aria-label="Use dark theme"
        aria-pressed="false"
      >
        <svg aria-hidden="true" viewBox="0 0 24 24" width="18" height="18">
          <path
            d="M12 3v2m0 14v2M3 12h2m14 0h2m-3.64-6.36-1.42 1.42M8.06 16.94l-1.42 1.42m0-12.72 1.42 1.42m7.88 9.88 1.42 1.42M16 12a4 4 0 1 1-8 0 4 4 0 0 1 8 0Z"
          ></path>
        </svg>
        <span>Theme</span>
      </button>
      <a class="button button-small" href={site.repository}>GitHub</a>
    </div>

    <details class="mobile-nav">
      <summary>Menu</summary>
      <nav aria-label="Mobile navigation">
        {
          primaryNavigation.map((item) => (
            <a
              href={item.href}
              aria-current={isCurrent(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
        <a href="/downloads/">Downloads</a>
        <a href={site.repository}>GitHub</a>
      </nav>
    </details>
  </div>
</header>
