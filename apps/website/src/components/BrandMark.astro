---
import markDarkUrl from "../../../../assets/brand/quireforge-mark-dark.svg?url";
import markUrl from "../../../../assets/brand/quireforge-mark.svg?url";

type Props = {
  size?: number;
  class?: string;
};

const { size = 40, class: className } = Astro.props;
---

<span class:list={["brand-mark", className]} aria-hidden="true">
  <img
    class="brand-mark-light"
    src={markUrl}
    width={size}
    height={size}
    alt=""
  />
  <img
    class="brand-mark-dark"
    src={markDarkUrl}
    width={size}
    height={size}
    alt=""
  />
</span>
