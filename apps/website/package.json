{
  "name": "@quireforge/website",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The static QuireForge project website.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.12.0 <23"
  },
  "scripts": {
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "check": "ASTRO_TELEMETRY_DISABLED=1 astro check",
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "validate:dist": "node scripts/validate-dist.mjs"
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.3",
    "astro": "7.1.2"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "9.39.5",
    "@playwright/test": "1.61.1",
    "@types/node": "22.20.1",
    "@typescript-eslint/parser": "8.64.0",
    "eslint": "9.39.5",
    "eslint-plugin-astro": "1.7.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "prettier": "3.9.5",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
